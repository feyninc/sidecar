{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@sidecar/core": ["packages/core/src/index.ts"],
      "@sidecar/client": ["packages/client/src/index.ts"],
      "@sidecar/auth": ["packages/auth/src/index.ts"],
      "@sidecar/auth/*": ["packages/auth/src/*"],
      "@sidecar/anthropic": ["packages/anthropic/src/index.ts"],
      "@sidecar/anthropic/agent": ["packages/anthropic/src/agent.ts"],
      "@sidecar/anthropic/command": ["packages/anthropic/src/command.ts"],
      "@sidecar/anthropic/components": ["packages/anthropic/src/components.tsx"],
      "@sidecar/anthropic/hooks": ["packages/anthropic/src/hooks.ts"],
      "@sidecar/anthropic/mcp": ["packages/anthropic/src/mcp.ts"],
      "@sidecar/anthropic/plugin": ["packages/anthropic/src/plugin.ts"],
      "@sidecar/anthropic/skill": ["packages/anthropic/src/skill.ts"],
      "@sidecar/anthropic/*": ["packages/anthropic/src/*"],
      "@sidecar/compiler": ["packages/compiler/src/index.ts"],
      "@sidecar/server": ["packages/server/src/index.ts"],
      "@sidecar/server/proxy": ["packages/server/src/proxy.ts"],
      "@sidecar/react": ["packages/react/src/index.ts"],
      "@sidecar/native": ["packages/native/src/index.ts"],
      "@sidecar/native/components": ["packages/native/src/components/index.tsx"],
      "@sidecar/native/styles.css": ["packages/native/src/styles.css"],
      "@sidecar/native/*": ["packages/native/src/*"],
      "@sidecar/openai": ["packages/openai/src/index.ts"],
      "@sidecar/openai/components": ["packages/openai/src/components.tsx"],
      "@sidecar/openai/official": ["packages/openai/src/official.ts"],
      "@sidecar/openai/*": ["packages/openai/src/*"],
      "@openai/apps-sdk-ui/css": ["packages/openai/src/styles.d.ts"],
      "@openai/apps-sdk-ui/*": ["node_modules/@openai/apps-sdk-ui/dist/types/*"]
    }
  },
  "include": ["packages/**/*.ts", "packages/**/*.tsx", "examples/**/*.ts", "tsup.config.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "out", "dist"]
}
