# Preferred private/self-hosted provider. Uncomment after completing Schwab OAuth.
# MARKET_DATA_PROVIDER=schwab
# SCHWAB_CLIENT_ID=
# SCHWAB_CLIENT_SECRET=
# SCHWAB_REFRESH_TOKEN=

# Short-lived alternative for development (normally expires in about 30 minutes).
# SCHWAB_ACCESS_TOKEN=
# SCHWAB_ACCESS_TOKEN_EXPIRES_AT=

# No-key development fallback. Broad international coverage, but unofficial and
# not suitable for a public/production or trading-critical service.
MARKET_DATA_PROVIDER=yahoo

# Optional overrides.
# SCHWAB_MARKET_DATA_BASE_URL=https://api.schwabapi.com/marketdata/v1
# SCHWAB_OAUTH_TOKEN_URL=https://api.schwabapi.com/v1/oauth/token
# SCHWAB_HTTP_TIMEOUT_MS=8000
